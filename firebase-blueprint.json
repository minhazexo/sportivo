{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "favoriteTeams": { "type": "array" },
        "followingLeagues": { "type": "array" },
        "bookmarkedArticles": { "type": "array" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Article": {
      "title": "News Article",
      "description": "Sports news article content",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "thumbnail": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array" },
        "authorId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "views": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "category", "authorId", "status", "createdAt"]
    },
    "Comment": {
      "title": "Article Comment",
      "description": "User interaction on articles",
      "type": "object",
      "properties": {
        "articleId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["articleId", "userId", "content", "createdAt"]
    },
    "Match": {
      "title": "Sports Match",
      "description": "Real-time match data",
      "type": "object",
      "properties": {
        "matchId": { "type": "string" },
        "leagueId": { "type": "string" },
        "homeTeamId": { "type": "string" },
        "awayTeamId": { "type": "string" },
        "homeScore": { "type": "number" },
        "awayScore": { "type": "number" },
        "status": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "timeline": { "type": "array" }
      },
      "required": ["matchId", "homeTeamId", "awayTeamId", "status", "startTime"]
    },
    "Analytic": {
      "title": "User Analytics",
      "description": "Tracking user engagement and clicks",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "targetId": { "type": "string" },
        "duration": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "timestamp"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles and settings"
    },
    "articles": {
      "schema": "Article",
      "description": "Sports news articles"
    },
    "articles/{articleId}/comments": {
      "schema": "Comment",
      "description": "Comments on articles"
    },
    "matches": {
      "schema": "Match",
      "description": "Live and scheduled match data"
    },
    "analytics": {
      "schema": "Analytic",
      "description": "Aggregated user tracking data"
    }
  }
}
