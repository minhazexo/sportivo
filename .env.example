# Sportivo Environment Variables
# Copy this file to .env and fill in your actual values

# ==========================================
# Google Gemini AI
# ==========================================
# Required for AI content generation (headlines, articles, summaries)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ==========================================
# Firebase Client SDK (Browser-side)
# ==========================================
# Required for Authentication and Firestore (uses firebase-applet-config.json)
# Get your config from: https://console.firebase.google.com
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# ==========================================
# NewsAPI.org
# ==========================================
# Required for sports news integration
# Get your key from: https://newsapi.org/register
NEWSAPI_API_KEY="your-newsapi-key"

# ==========================================
# TheSportsDB
# ==========================================
# Free tier - no API key required
# Base URL: https://www.thesportsdb.com/api/v1/json/3
# Optional: Get a free API key for higher rate limits
# VITE_THESPORTSDB_KEY="your-thesportsdb-key"

# ==========================================
# JWT Authentication
# ==========================================
# REQUIRED for production. A strong random secret used to sign JWT tokens.
# Generate one with: openssl rand -hex 32
JWT_SECRET="your-jwt-secret"

# JWT token expiry duration (default: 7d)
# Uses vercel/ms format: e.g. 7d, 24h, 60m, 30d
# JWT_EXPIRES_IN="7d"

# ==========================================
# Application URLs
# ==========================================
# The URL where this applet is hosted
APP_URL="http://localhost:3000"

# The public URL of the website (for SEO and sitemaps)
VITE_SITE_URL="http://localhost:3000"

# ==========================================
# Optional Integrations
# ==========================================
# Google Analytics measurement ID
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Google AdSense client ID
VITE_ADSENSE_CLIENT="ca-pub-XXXXXXXXXX"

# API-Football API key (for live scores, stats)
# Get your key from: https://www.api-football.com/
VITE_API_FOOTBALL_KEY="your-api-football-key"

# SportMonks API token (for cricket data)
# Get your token from: https://www.sportmonks.com/
VITE_SPORTMONKS_TOKEN="your-sportmonks-token"
