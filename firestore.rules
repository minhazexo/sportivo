rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['user', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'slug', 'content', 'category', 'authorId', 'status', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.status in ['draft', 'published', 'archived'] &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['articleId', 'userId', 'content', 'createdAt']) &&
             data.content is string && data.content.size() <= 1000 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time &&
             exists(/databases/$(database)/documents/articles/$(data.articleId));
    }

    function isValidAnalytic(data) {
      return data.keys().hasAll(['type', 'timestamp']) &&
             data.type is string && data.type.size() <= 50 &&
             data.timestamp == request.time;
    }

    // Collection Matches
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // System defined
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isEmailVerified() && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if isEmailVerified() && isOwner(userId) && 
                      isValidUser(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'favoriteTeams', 'followingLeagues', 'bookmarkedArticles']) &&
                      incoming().role == existing().role;
    }

    match /articles/{articleId} {
      allow get: if true;
      allow list: if (resource != null && resource.data.status == 'published') || isAdmin();
      allow create: if isAdmin() && isValidArticle(incoming());
      allow update: if isAdmin() && isValidArticle(incoming()) &&
                      (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'thumbnail', 'status', 'updatedAt']) ||
                       incoming().diff(existing()).affectedKeys().hasOnly(['views'])); 
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isEmailVerified() && isValidComment(incoming());
        allow update: if isEmailVerified() && isOwner(existing().userId) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['content']) &&
                        incoming().content is string && incoming().content.size() <= 1000;
        allow delete: if isAdmin() || (isSignedIn() && isOwner(existing().userId));
      }
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics/{analyticId} {
      allow create: if isSignedIn() && isValidAnalytic(incoming());
      allow read: if isAdmin();
    }
  }
}
